# Example environment variables for 1-news-summarizer API
# Copy this file to `.env` in the same directory (1-news-summarizer/api/.env)
# and replace the placeholder values with your real credentials.

# OpenAI API key used by the ChatClient / LangChain integration
# e.g. OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=

# Optional log level (defaults to INFO)
LOG_LEVEL=INFO
